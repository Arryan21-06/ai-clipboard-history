{
  "manifest_version": 3,
  "name": "AI Clipboard History",
  "version": "1.0",
  "description": "AI Clipboard History Extension",
  "permissions": [
    "clipboardRead",
    "storage",
    "activeTab",
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
